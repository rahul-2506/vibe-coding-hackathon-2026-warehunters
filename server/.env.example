# ==============================================================================
# ReviewLens Server (Express Node.js Backend) Environment Configuration
# ==============================================================================

# Supabase Credentials (Used by backend connection pool)
SUPABASE_URL=https://your-supabase-project-url.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Server Listen Port
PORT=5000

# JSON Web Token Secret
JWT_SECRET=your-jwt-signing-secret-here

# Frontend Application URL (For CORS policies)
FRONTEND_URL=http://localhost:5173

# Python ML Microservice URL (FastAPI AI Bridge proxy)
ML_SERVICE_URL=http://localhost:18001
PRICE_SCRAPER_URL=http://localhost:18001

# Centralized API Key for AI service interactions (Gemini/Groq)
AI_API_KEY=your-gemini-or-groq-api-key-here
