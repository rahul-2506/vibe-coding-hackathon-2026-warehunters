# ==============================================================================
# ReviewLens ML Service (FastAPI Python AI Microservice) Environment Configuration
# ==============================================================================

# Port to bind FastAPI web app to
PORT=8000

# Allowed Frontend URL for secure CORS restriction
FRONTEND_URL=http://localhost:5173

# API Key for Gemini primary engine
GEMINI_API_KEY=your_gemini_api_key_here

# API Key for Groq backup engine (Optional fallback)
GROQ_API_KEY=your_groq_api_key_here

# Supabase Credentials (Used to fetch live products, reviews, and knowledge base)
SUPABASE_URL=https://your-supabase-project-url.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
